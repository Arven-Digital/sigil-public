# Sigil public integration placeholders.
# Do not commit production API, Guardian, database, cache, OAuth, provider, or service secrets here.

# Public dashboard/API defaults used by examples and local frontend smoke tests.
NEXT_PUBLIC_API_URL=https://api.sigil.codes/v1
NEXT_PUBLIC_SITE_URL=https://sigil.codes

# Agent integration examples only. Use placeholders in docs and local-only values in real shells.
SIGIL_API_KEY=sgil_your_key_here
SIGIL_ACCOUNT_ADDRESS=0xYourSigilAccount
SIGIL_AGENT_PRIVATE_KEY=0xYourAgentPrivateKey
SIGIL_CHAIN_ID=137
SIGIL_RPC_URL=https://rpc-mainnet.matic.quiknode.pro

# Contract deployment scripts read a local private key from the environment.
# Keep real deployer keys in an untracked .env file or secret manager, never in this repository.
DEPLOYER_PRIVATE_KEY=0xYourLocalOnlyDeployerPrivateKey
