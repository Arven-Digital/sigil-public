{
  "name": "sigil-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Open security protocol for AI agent wallets",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "audit:high": "pnpm audit --audit-level high",
    "proof:public": "node scripts/public-proof.mjs",
    "ci": "pnpm install --frozen-lockfile && pnpm audit:high && pnpm test && pnpm build && pnpm lint && pnpm proof:public"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.1"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "pino-pretty": "^13.1.3"
  },
  "pnpm": {
    "overrides": {
      "vite@>=7.0.0 <7.3.5": "7.3.5",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "hono@<4.12.25": "4.12.27",
      "@hono/node-server@<1.19.10": "1.19.14",
      "express-rate-limit@>=8.2.0 <8.2.2": "8.5.2",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.2",
      "axios@>=1.0.0 <1.16.0": "1.16.0",
      "ws@>=7.0.0 <7.5.11": "7.5.11",
      "ws@>=8.0.0 <8.21.0": "8.21.0",
      "form-data@>=4.0.0 <4.0.6": "4.0.6",
      "fast-uri@<=3.1.1": "3.1.3",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "defu@<=6.1.4": "6.1.5",
      "socket.io-parser@>=4.0.0 <4.2.6": "4.2.6",
      "lodash@>=4.0.0 <=4.17.23": "4.18.0",
      "fastify@>=5.3.2 <=5.8.4": "5.9.0",
      "nodemailer@<=9.0.0": "9.0.3",
      "h3@<1.15.6": "1.15.6"
